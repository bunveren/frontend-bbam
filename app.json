{
  "expo": {
    "name": "Body & Beyond AI Mentor",
    "slug": "body-and-beyond-ai-mentor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bbam.bodybeyond"
    },
    "android": {
      "package": "com.bbam.bodybeyond",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "63225d90-6e13-4214-af44-7150a523c4ab"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#585AD1",
          "androidMode": "default"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Body & Beyond to access your camera for pose detection."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "ndkVersion": "27.0.12077973"
          }
        }
      ],
      "react-native-vision-camera",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-background-task"
    ]
  }
}
